# Notion API 閰嶇疆
# 浠?https://www.notion.so/my-integrations 鑾峰彇
NOTION_TOKEN=
# 浣犵殑 Notion 鏁版嵁搴?ID (浠庢暟鎹簱椤甸潰 URL 鑾峰彇)
NOTION_DATABASE_ID=

# Optional: use data source id directly on new Notion API
NOTION_DATA_SOURCE_ID=
# Optional: set to database when NOTION_DATABASE_ID is a database_id
# NOTION_ID_KIND=database

# Upstash Redis (鐢ㄤ簬鐐硅禐鍔熻兘)
# 浠?https://upstash.com 鑾峰彇
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Giscus 璇勮閰嶇疆
# 浠?https://giscus.app/zh-CN 鑾峰彇閰嶇疆
# 浠撳簱 (鏍煎紡: owner/repo)
NEXT_PUBLIC_GISCUS_REPO=
# 浠撳簱 ID (鍦?giscus.app 閰嶇疆椤甸潰鑾峰彇)
NEXT_PUBLIC_GISCUS_REPO_ID=
# Discussion 鍒嗙被鍚嶇О
NEXT_PUBLIC_GISCUS_CATEGORY=
# Discussion 鍒嗙被 ID (鍦?giscus.app 閰嶇疆椤甸潰鑾峰彇)
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
# 鏄犲皠鏂瑰紡 (pathname | url | title | og:title | specific | number)
NEXT_PUBLIC_GISCUS_MAPPING=pathname
# 鏄惁鍚敤鍙嶅簲 (0 | 1)
NEXT_PUBLIC_GISCUS_REACTIONS_ENABLED=1
# 鏄惁鍙戦€佸厓鏁版嵁 (0 | 1)
NEXT_PUBLIC_GISCUS_EMIT_METADATA=0
# 杈撳叆妗嗕綅缃?(top | bottom)
NEXT_PUBLIC_GISCUS_INPUT_POSITION=top
# 涓婚 (github-light | github-dark | preferred_color_scheme 绛?
NEXT_PUBLIC_GISCUS_THEME=preferred_color_scheme
# 璇█ (zh-CN | en 绛?
NEXT_PUBLIC_GISCUS_LANG=zh-CN

# Vercel Analytics (鑷姩鍚敤锛屾棤闇€閰嶇疆)
# 閮ㄧ讲鍒?Vercel 鍚庤嚜鍔ㄦ敹闆嗘€ц兘鏁版嵁