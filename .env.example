# Notion API 配置
# 从 https://www.notion.so/my-integrations 获取
NOTION_TOKEN=
# 你的 Notion 数据库 ID (从数据库页面 URL 获取)
NOTION_DATABASE_ID=

# 可选：Upstash Redis (用于点赞功能)
# 从 https://upstash.com 获取
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# 可选：Giscus 评论配置
# 从 https://giscus.app/zh-CN 获取配置
# NEXT_PUBLIC_GISCUS_REPO=
# NEXT_PUBLIC_GISCUS_REPO_ID=
# NEXT_PUBLIC_GISCUS_CATEGORY=
# NEXT_PUBLIC_GISCUS_CATEGORY_ID=
# NEXT_PUBLIC_GISCUS_MAPPING=
# NEXT_PUBLIC_GISCUS_REACTIONS_ENABLED=
# NEXT_PUBLIC_GISCUS_EMIT_METADATA=
# NEXT_PUBLIC_GISCUS_INPUT_POSITION=
# NEXT_PUBLIC_GISCUS_THEME=
# NEXT_PUBLIC_GISCUS_LANG=