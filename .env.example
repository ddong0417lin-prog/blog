# Notion API 配置
# 从 https://www.notion.so/my-integrations 获取
NOTION_TOKEN=
# 你的 Notion 数据库 ID (从数据库页面 URL 获取)
NOTION_DATABASE_ID=

# Upstash Redis (用于点赞功能)
# 从 https://upstash.com 获取
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Giscus 评论配置
# 从 https://giscus.app/zh-CN 获取配置
# 仓库 (格式: owner/repo)
NEXT_PUBLIC_GISCUS_REPO=
# 仓库 ID (在 giscus.app 配置页面获取)
NEXT_PUBLIC_GISCUS_REPO_ID=
# Discussion 分类名称
NEXT_PUBLIC_GISCUS_CATEGORY=
# Discussion 分类 ID (在 giscus.app 配置页面获取)
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
# 映射方式 (pathname | url | title | og:title | specific | number)
NEXT_PUBLIC_GISCUS_MAPPING=pathname
# 是否启用反应 (0 | 1)
NEXT_PUBLIC_GISCUS_REACTIONS_ENABLED=1
# 是否发送元数据 (0 | 1)
NEXT_PUBLIC_GISCUS_EMIT_METADATA=0
# 输入框位置 (top | bottom)
NEXT_PUBLIC_GISCUS_INPUT_POSITION=top
# 主题 (github-light | github-dark | preferred_color_scheme 等)
NEXT_PUBLIC_GISCUS_THEME=preferred_color_scheme
# 语言 (zh-CN | en 等)
NEXT_PUBLIC_GISCUS_LANG=zh-CN

# Vercel Analytics (自动启用，无需配置)
# 部署到 Vercel 后自动收集性能数据